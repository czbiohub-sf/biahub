profiles {
    // Default: run locally (Nextflow local executor)
    standard {
        process.executor = 'local'
    }

    // Slurm: submit tasks via sbatch
    // Usage: nextflow run main.nf -profile slurm --python_bin /path/to/venv/bin/python --mode fail
    slurm {
        process {
            executor = 'slurm'
            queue = 'cpu'
            cpus = 1
            memory = '1 GB'
            time = '1m'
        }
    }
}
