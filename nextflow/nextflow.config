params {
    input_zarr        = null
    output_dir        = null
    flat_field_config = null
    deskew_config     = null
    reconstruct_config = null
    num_processes     = 1
    max_workers       = 50
    venv_path         = null
}

process {
    beforeScript = params.venv_path ? "source ${params.venv_path}/bin/activate" : ''
    executor = 'local'

    withLabel: 'cpu_small' {
        cpus   = 1
        memory = '4 GB'
        time   = '30m'
    }
    withLabel: 'cpu_medium' {
        cpus   = 4
        memory = '16 GB'
        time   = '2h'
    }
    withLabel: 'gpu' {
        cpus   = 4
        memory = '32 GB'
        time   = '2h'
    }
}

profiles {
    local {
        process.executor = 'local'
    }

    slurm {
        executor {
            name = 'slurm'
            queueSize = params.max_workers
            submitRateLimit = '20/1min'
        }
        process {
            executor = 'slurm'
            queue = 'cpu'
        }
        process {
            withLabel: 'cpu_small' {
                queue  = 'cpu'
                cpus   = 1
                memory = '4 GB'
                time   = '1h'
            }
            withLabel: 'cpu_medium' {
                queue  = 'cpu'
                cpus   = 4
                memory = '16 GB'
                time   = '2h'
            }
            withLabel: 'gpu' {
                queue  = 'gpu'
                cpus   = 4
                memory = '32 GB'
                time   = '2h'
                clusterOptions = '--gres=gpu:1'
            }
        }
    }
}

dag {
    enabled   = true
    overwrite = true
    file      = 'nextflow/output/dag.html'
}

report {
    enabled   = true
    overwrite = true
    file      = 'nextflow/output/report.html'
}

trace {
    enabled   = true
    overwrite = true
    file      = 'nextflow/output/trace.txt'
}

timeline {
    enabled   = true
    overwrite = true
    file      = 'nextflow/output/timeline.html'
}
