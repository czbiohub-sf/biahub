params {
    // Pipeline-level input/output. `input` is the raw source — it may NOT be a
    // zarr store (e.g. a raw acquisition that a convert step turns into zarr).
    // Individual step modules always operate on zarr (input_zarr/output_zarr).
    input             = null
    output            = null
    deskew_config     = null
    flat_field_config = null
    biahub_project    = null
    work_dir          = null
    max_positions     = 0
    max_workers       = 100
}

process {
    executor = 'local'

    withLabel: 'cpu_local' {
        cpus   = 1
        memory = '8 GB'
    }
    withLabel: 'cpu' {
        cpus   = 4
        memory = '32 GB'
        time   = '2h'
    }
}

profiles {
    local {
        process.executor = 'local'
    }
    slurm {
        executor {
            name = 'slurm'
            queueSize = params.max_workers
            submitRateLimit = '50/1min'
        }
        process {
            executor = 'slurm'
            queue = 'cpu'

            withLabel: 'cpu_local' {
                executor = 'local'
                cpus   = 1
                memory = '12 GB'
            }
            withLabel: 'cpu' {
                queue = 'cpu'
            }
        }
    }
}

workDir = params.work_dir ?: 'work'

dag {
    enabled   = true
    overwrite = true
    file      = "${params.output}/nextflow/dag.html"
}

report {
    enabled   = true
    overwrite = true
    file      = "${params.output}/nextflow/report.html"
}

trace {
    enabled   = true
    overwrite = true
    file      = "${params.output}/nextflow/trace.txt"
}

timeline {
    enabled   = true
    overwrite = true
    file      = "${params.output}/nextflow/timeline.html"
}
