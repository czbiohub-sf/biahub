params {
    input              = null
    output             = null
    flat_field_config  = null
    deskew_config      = null
    reconstruct_config = null
    predict_config     = null
    track_config       = null
    concatenate_config = null
    rename_prefix      = null
    rename_suffix      = null
    biahub_project     = null
    viscy_project      = null
    max_positions      = 0
    max_workers        = 100
    qc_config_dir      = null
    qc_project         = null
    qc_report_dir      = null
    qc_report_static   = false
    qc_chunk_size      = 10
    clean_intermediates = false
}

process {
    executor = 'local'

    withLabel: 'cpu_local' {
        cpus   = 1
        memory = '8 GB'
    }
    withLabel: 'cpu' {
        cpus   = 4
        memory = '32 GB'
        time   = '2h'
    }
    withLabel: 'gpu' {
        cpus   = 4
        memory = '32 GB'
        time   = '2h'
    }
}

profiles {
    local {
        process.executor = 'local'
    }
    slurm {
        executor {
            name = 'slurm'
            queueSize = params.max_workers
            submitRateLimit = '50/1min'
        }
        process {
            executor = 'slurm'
            queue = 'cpu'
        }
        process {
            withLabel: 'cpu_local' {
                executor = 'local'
                cpus   = 1
                memory = '12 GB'
            }
            withLabel: 'cpu' {
                queue = 'cpu'
            }
            withLabel: 'gpu' {
                queue = 'gpu'
                clusterOptions = '--gres=gpu:1'
            }
        }
    }
}

// Default work dir lives under the run's output. Override with Nextflow's
// native `-work-dir`/`-w` CLI flag (e.g. to use fast local scratch).
workDir = "${params.output}/nextflow/work"

dag {
    enabled   = true
    overwrite = true
    file      = "${params.output}/nextflow/dag.html"
}

report {
    enabled   = true
    overwrite = true
    file      = "${params.output}/nextflow/report.html"
}

trace {
    enabled   = true
    overwrite = true
    file      = "${params.output}/nextflow/trace.txt"
}

timeline {
    enabled   = true
    overwrite = true
    file      = "${params.output}/nextflow/timeline.html"
}
